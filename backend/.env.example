# Copy this file to .env and fill in what you have.
# The app runs without any of the API keys below; keyed modules show a
# "key not configured" card until their key is added.

# --- Core ---
# Secret used to sign session tokens. Change it to any long random string.
SECRET_KEY=change-me-to-a-long-random-string

# Postgres (the project default). Create the database once:
#   createdb -U postgres allforone
# Then set your own user/password here:
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/allforone
# Dev fallback if you want to run without Postgres for a moment:
# DATABASE_URL=sqlite:///./allforone.db

# --- API keys (all optional, see SOURCES.md for how to get each) ---
# TMDB v4 Read Access Token (Settings > API on themoviedb.org)
TMDB_TOKEN=

# football-data.org token (emailed on registration)
FOOTBALL_DATA_TOKEN=

# balldontlie API key (app.balldontlie.io)
BALLDONTLIE_KEY=

# IGDB via Twitch (dev.twitch.tv console)
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Self-hosted vlrggapi base URL, e.g. http://localhost:8001 (esports module)
VLRGG_BASE_URL=

# Optional: shared Redis cache. Leave empty for the in-process cache (fine on a
# single free instance). Set only when scaling to multiple instances/workers,
# e.g. redis://default:PASSWORD@host:6379
REDIS_URL=

# CricketData.org key (free, 100/day) - sign up at cricketdata.org, key is instant
CRICAPI_KEY=

# api-sports.io key (free, 100/day) - powers the tennis module (beta). Different
# service from football-data.org; register at api-sports.io dashboard.
API_SPORTS_KEY=
